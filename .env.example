# shellcheck disable=SC2034

LOG_LEVEL=
DB_NAME=
LOGS_PATH=
TZ=America/Vancouver
FRONTEND_PORT=3000
PUSHOVER_USER=
PUSHOVER_TOKEN=
PUSHOVER_LIVE_TOKEN=      # Optional, falls back to PUSHOVER_TOKEN (YouTube/Twitch/Kick share this)
PUSHOVER_BRIEFING_TOKEN=  # Optional, falls back to PUSHOVER_TOKEN
YT_CHANNEL_NAMES=
TWITCH_CHANNEL_NAMES=
KICK_CHANNEL_NAMES=       # Kick channel slugs, comma-separated (e.g. destiny,xqc)
KICK_CLIENT_ID=           # From https://dev.kick.com app (OAuth Client Credentials)
KICK_CLIENT_SECRET=       # From https://dev.kick.com app
OFFLINE_NOTIFICATIONS=
BRIEFING_MODEL=google:gemini-3.5-flash
GOOGLE_GENERATIVE_AI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
TAVILY_API_KEY=
CHANNELS_CONFIG_PATH=
BRIEFINGS_PATH=

# Fastmail (JMAP email monitoring + CalDAV calendar)
FASTMAIL_API_TOKEN=       # API token from Fastmail Settings → Privacy & Security
FASTMAIL_APP_PASSWORD=    # App password for CalDAV (Settings → Privacy & Security → Third-party apps)
FASTMAIL_USERNAME=        # e.g. user@fastmail.com
PARCEL_API_KEY=           # Parcel.app API key (optional, enables parcel tracking)
EXTRACTION_MODEL=google:gemini-3.1-flash-lite       # Parcel extraction
CALENDAR_EXTRACTION_MODEL=google:gemini-3.5-flash   # Calendar extraction (stronger)
TRIAGE_MODEL=google:gemini-3.1-flash-lite           # Shared email relevance triage
PUSHOVER_CALENDAR_TOKEN=  # Optional, falls back to PUSHOVER_TOKEN
FASTMAIL_CALENDAR_ID=     # Optional, auto-discovers default calendar

# Media recommendations
TMDB_API_KEY=              # themoviedb.org API key (v3 key or v4 read access token)
RECS_SHORTLIST_MODEL=openai:gpt-5.6-luna
RECS_SELECTION_MODEL=openai:gpt-5.6
TASTE_REFLECTION_MODEL=openai:gpt-5.6-luna
TASTE_REFLECTION_SCHEDULE= # Optional, default "0 0 4 * * 0" (Sunday 4am)
RECS_SCHEDULE=             # Optional, default "0 0 17 * * 1,3,5" (Mon/Wed/Fri 5pm)
RECS_PUBLIC_URL=http://omni.boris
PUSHOVER_RECS_TOKEN=       # Optional, falls back to PUSHOVER_TOKEN
PLEX_URL=http://plex.boris
PLEX_TOKEN=
PLEX_ACCOUNT_ID=           # Optional; required if history contains multiple Plex users
RADARR_URL=http://radarr.boris
RADARR_API_KEY=
RADARR_ROOT_FOLDER_PATH=
RADARR_QUALITY_PROFILE_ID=
SONARR_URL=http://sonarr.boris
SONARR_API_KEY=
SONARR_ROOT_FOLDER_PATH=
SONARR_QUALITY_PROFILE_ID=

# Podcast recommendations (enabled by setting PODCAST_TASTE_PATH)
PODCAST_TASTE_PATH=          # Markdown listener profile; doubles as the feature flag
PODCAST_RECS_SCHEDULE=       # Optional, default "0 0 11 * * 1,3,5" (Mon/Wed/Fri 11am)
PUSHOVER_PODCAST_TOKEN=      # Optional, falls back to PUSHOVER_TOKEN
CASTRO_ACCESS_ID=            # Optional: Castro device credential UUID
CASTRO_SECRET_KEY=           # Optional: Castro device HMAC secret (keep private)
PODCASTINDEX_KEY=            # Optional: Podcast Index API key (guest-appearance discovery)
PODCASTINDEX_SECRET=         # Optional: Podcast Index API secret (QUOTE it — secrets contain #)
PODCAST_VOICE_ROTATION_MAX=  # Optional, default 12 (voices person-searched per run)
PODCAST_MAX_GUEST_PICKS=     # Optional, default 6 (Tier-1 guest picks cap per run)
PODCAST_TASTE_REFLECTION_MODEL=    # Optional, default openai:gpt-5.6-luna
PODCAST_TASTE_REFLECTION_SCHEDULE= # Optional, default "0 0 5 * * 0" (Sunday 5am)

# PressPods: article → podcast episodes (enabled by setting PRESSPODS_AUTH_TOKEN)
PRESSPODS_AUTH_TOKEN=        # Long random secret; authenticates /pods/episodes + /pods/rss
PRESSPODS_PUBLIC_URL=        # Optional: public origin for RSS enclosure URLs (else derived per request)
PRESSPODS_AUDIO_DIR=         # Optional: episode MP3 dir (default: press-pods-audio next to the DB)
PRESSPODS_METADATA_MODEL=    # Optional, default google:gemini-3.5-flash (rates each retriever)
PRESSPODS_CLEANING_MODEL=    # Optional, default google:gemini-3.5-flash (narration rewrite)
PRESSPODS_TTS_PROVIDER=higgs # TTS backend: higgs (self-hosted, default) or elevenlabs
PRESSPODS_TTS_URL=           # mlx-audio server URL, e.g. http://10.10.1.90:8000 (required for higgs)
PRESSPODS_TTS_MODEL=         # Optional: Higgs model repo (default bosonai/higgs-audio-v3-tts-4b)
ELEVENLABS_API_KEY=          # ElevenLabs v3 TTS (required when PRESSPODS_TTS_PROVIDER=elevenlabs)
ELEVENLABS_VOICE_MALE=       # Optional: voice id for male-author narration (default: Brian)
ELEVENLABS_VOICE_FEMALE=     # Optional: voice id for female/unknown-author narration (default: Matilda)
MISTRAL_API_KEY=             # Optional: only used by the tts-bakeoff comparison tool
JINA_API_KEY=                # Optional: enables the Jina.ai Reader retriever
PUSHOVER_PRESSPODS_TOKEN=    # Optional, falls back to PUSHOVER_TOKEN
KARAKEEP_URL=                # Optional: bookmark submitted articles in Karakeep
KARAKEEP_API_KEY=            # Optional

# Email via SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
LOGS_EMAIL_TO=
