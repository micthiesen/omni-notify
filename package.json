{
  "name": "omni-notify",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "dotenvx run -- tsx watch src/index.ts",
    "run-task": "dotenvx run -- tsx src/index.ts --run-task",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format .",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "test": "vitest",
    "docker:build": "docker build -t omni-notify .",
    "docker:publish": "docker push omni-notify",
    "docker:build-and-publish": "pnpm run docker:build && pnpm run docker:publish",
    "docker:dev": "docker run -p 3000:3000 --rm --name omni-notify omni-notify"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.8",
    "@ai-sdk/google": "^4.0.8",
    "@ai-sdk/openai": "^4.0.7",
    "@hono/node-server": "^2.0.8",
    "@micthiesen/mitools": "^2.3.4",
    "@mozilla/readability": "^0.6.0",
    "ai": "^7.0.15",
    "amazon-cognito-identity-js": "^6.3.18",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "eventsource": "^4.1.0",
    "got": "^15.1.0",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.27",
    "html-entities": "^2.6.0",
    "html-to-text": "^10.0.0",
    "jmap-jam": "^0.13.2",
    "linkedom": "^0.18.12",
    "node-cron": "^4.5.0",
    "node-schedule": "^2.1.1",
    "nodemailer": "^9.0.3",
    "p-queue": "^9.3.1",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@dotenvx/dotenvx": "^2.1.4",
    "@types/html-to-text": "^9.0.4",
    "@types/node": "24.13.2",
    "@types/nodemailer": "^8.0.1",
    "@types/turndown": "^5.0.6",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": "24.18.0",
    "pnpm": "11.10.0"
  },
  "packageManager": "pnpm@11.10.0"
}
