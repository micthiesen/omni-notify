{
  "name": "omni-notify",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "dotenvx run -- tsx watch src/index.ts",
    "run-task": "dotenvx run -- tsx src/index.ts --run-task",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format .",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "test": "vitest",
    "docker:build": "docker build -t omni-notify .",
    "docker:publish": "docker push omni-notify",
    "docker:build-and-publish": "pnpm run docker:build && pnpm run docker:publish",
    "docker:dev": "docker run -p 3000:3000 --rm --name omni-notify omni-notify"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.15",
    "@ai-sdk/google": "^4.0.16",
    "@ai-sdk/openai": "^4.0.14",
    "@extractus/article-extractor": "^8.1.0",
    "@hono/node-server": "^2.0.9",
    "@micthiesen/mitools": "^2.5.1",
    "@mistralai/mistralai": "^2.5.0",
    "@mozilla/readability": "^0.6.0",
    "@postlight/parser": "^2.2.3",
    "ai": "^7.0.28",
    "amazon-cognito-identity-js": "^6.3.20",
    "cron-parser": "^4.9.0",
    "date-fns": "^4.4.0",
    "date-fns-tz": "^3.2.0",
    "eventsource": "^4.1.0",
    "fluent-ffmpeg": "2.1.3",
    "fractional-indexing": "^4.0.0",
    "got": "^15.1.0",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.30",
    "html-entities": "^2.6.0",
    "html-to-text": "^10.0.0",
    "jmap-jam": "^0.13.2",
    "linkedom": "^0.18.13",
    "music-metadata": "^11.14.0",
    "node-cron": "^4.6.0",
    "node-id3": "^0.2.9",
    "node-schedule": "^2.1.1",
    "nodemailer": "^9.0.3",
    "p-queue": "^9.3.1",
    "podcast": "^2.0.1",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@dotenvx/dotenvx": "^2.9.0",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/html-to-text": "^9.0.4",
    "@types/node": "24.13.3",
    "@types/nodemailer": "^8.0.1",
    "@types/turndown": "^5.0.6",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": "24.18.0",
    "pnpm": "11.13.1"
  },
  "packageManager": "pnpm@11.13.1"
}
